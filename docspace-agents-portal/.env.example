DOCSPACE_BASE_URL=https://your-docspace.example.com
DOCSPACE_AUTH_TOKEN=YOUR_DOCSPACE_SERVICE_TOKEN_OPTIONAL
SESSION_TTL_SECONDS=604800

# openai | ollama
LLM_PROVIDER=ollama

OPENAI_API_KEY=
OPENAI_CHAT_MODEL=gpt-4o-mini
OPENAI_EMBED_MODEL=text-embedding-3-small

OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_CHAT_MODEL=gemma3:4b
OLLAMA_EMBED_MODEL=nomic-embed-text

PORT=5190
PUBLIC_BASE_URL=http://localhost:5190
DOCSPACE_MAX_FILE_BYTES=15000000
PUBLIC_FILE_TTL_SECONDS=86400

# ── Demo stand mode ──────────────────────────────────────────────────────────
# Set DEMO_MODE=true to enable the demo stand (no user login required).
# Requires DOCSPACE_AUTH_TOKEN to be set (used as the service token for all demo sessions).
# DEMO_MODE=true

# Name displayed in the Studio sidebar for the pre-seeded demo agent.
# DEMO_AGENT_NAME=Demo Assistant

# Optional: DocSpace room ID to attach to the demo agent's knowledge base.
# DEMO_KB_ROOM_ID=

# Session lifetime settings
# DEMO_SESSION_TTL_MINUTES=30
# DEMO_SESSION_IDLE_MINUTES=15
# DEMO_JANITOR_INTERVAL_SECONDS=60
