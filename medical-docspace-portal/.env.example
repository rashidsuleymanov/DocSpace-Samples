DOCSPACE_CLIENT_TEMPLATES_FOLDER_TITLE=Client Templates
# Optional: use exact folder ID if the folder isn't directly under the Forms room root/Templates.
# DOCSPACE_CLIENT_TEMPLATES_FOLDER_ID=2373836
