DOCSPACE_FORMS_TEMPLATES_FOLDER_TITLE=Templates
# Local store persistence (optional). For demo stands, prefer disabling persistence.
# MEDICAL_PORTAL_STORE_PATH=server/.data/store.json
# MEDICAL_PORTAL_STORE_PATH=off
ENABLE_DEBUG_API=false
DEMO_MODE=true
# Demo session lifecycle (server-side cookie session)
# DEMO_COOKIE_NAME=demo_sid
# DEMO_EMAIL_DOMAIN=demo.local
# DEMO_SESSION_TTL_MINUTES=45
# DEMO_SESSION_IDLE_MINUTES=20
# DEMO_SESSION_JANITOR_INTERVAL_SECONDS=60
